# Copy this file to `.env.local` (Next.js loads it automatically).
# `NEXT_PUBLIC_*` variables are exposed to the browser — do not put secrets here.

# Primary API host (no trailing slash). Server-side axios uses the first available:
# NEXT_PUBLIC_API_BASE_URL, then NEXT_PUBLIC_BACKEND_URL, then built-in fallbacks.
NEXT_PUBLIC_API_BASE_URL=https://app.wisdomtooth.tech

# Optional second candidate (same semantics). Leave empty if you only use NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_BACKEND_URL=
